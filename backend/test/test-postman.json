{
  "info": {
    "name": "BlueForce API Tests",
    "description": "Complete API test collection for BlueForce beach cleanup backend service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000",
      "type": "string"
    },
    {
      "key": "apiUrl",
      "value": "{{baseUrl}}/api",
      "type": "string"
    },
    {
      "key": "volunteerToken",
      "value": "your_volunteer_jwt_token_here",
      "type": "string"
    },
    {
      "key": "ngoToken",
      "value": "your_ngo_jwt_token_here",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "your_admin_jwt_token_here",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"Test123!\",\n  \"role\": \"volunteer\"\n}"
            },
            "url": {
              "raw": "{{apiUrl}}/auth/register",
              "host": ["{{apiUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{apiUrl}}/auth/login",
              "host": ["{{apiUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{volunteerToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{apiUrl}}/auth/me",
              "host": ["{{apiUrl}}"],
              "path": ["auth", "me"]
            }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{volunteerToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\"\n}"
            },
            "url": {
              "raw": "{{apiUrl}}/auth/profile",
              "host": ["{{apiUrl}}"],
              "path": ["auth", "profile"]
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{volunteerToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"password123\",\n  \"newPassword\": \"NewPassword123!\"\n}"
            },
            "url": {
              "raw": "{{apiUrl}}/auth/change-password",
              "host": ["{{apiUrl}}"],
              "path": ["auth", "change-password"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{volunteerToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{apiUrl}}/auth/logout",
              "host": ["{{apiUrl}}"],
              "path": ["auth", "logout"]
            }
          }
        },
        {
          "name": "Get All Users (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{apiUrl}}/auth/users",
              "host": ["{{apiUrl}}"],
              "path": ["auth", "users"]
            }
          }
        },
        {
          "name": "Get User Stats (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{apiUrl}}/auth/stats",
              "host": ["{{apiUrl}}"],
              "path": ["auth", "stats"]
            }
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "Get All Events",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiUrl}}/events",
              "host": ["{{apiUrl}}"],
              "path": ["events"]
            }
          }
        },
        {
          "name": "Get Events - Upcoming Only",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiUrl}}/events?upcoming=true",
              "host": ["{{apiUrl}}"],
              "path": ["events"],
              "query": [
                {
                  "key": "upcoming",
                  "value": "true"
                }
              ]
            }
          }
        },
        {
          "name": "Get Events - Filter by Location",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiUrl}}/events?location=Marina",
              "host": ["{{apiUrl}}"],
              "path": ["events"],
              "query": [
                {
                  "key": "location",
                  "value": "Marina"
                }
              ]
            }
          }
        },
        {
          "name": "Get Events - Filter by NGO",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiUrl}}/events?ngo_id=5",
              "host": ["{{apiUrl}}"],
              "path": ["events"],
              "query": [
                {
                  "key": "ngo_id",
                  "value": "5"
                }
              ]
            }
          }
        },
        {
          "name": "Get Event Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiUrl}}/events/1",
              "host": ["{{apiUrl}}"],
              "path": ["events", "1"]
            }
          }
        },
        {
          "name": "Create Event (NGO)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ngoToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ngo_id\": 5,\n  \"title\": \"Test Beach Cleanup\",\n  \"description\": \"This is a test event created via Postman\",\n  \"location\": \"Test Beach, Test City\",\n  \"date_time\": \"2024-03-15T09:00:00.000Z\"\n}"
            },
            "url": {
              "raw": "{{apiUrl}}/events",
              "host": ["{{apiUrl}}"],
              "path": ["events"]
            }
          }
        },
        {
          "name": "Update Event (NGO)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ngoToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Beach Cleanup Title\",\n  \"description\": \"Updated description for the event\"\n}"
            },
            "url": {
              "raw": "{{apiUrl}}/events/1",
              "host": ["{{apiUrl}}"],
              "path": ["events", "1"]
            }
          }
        },
        {
          "name": "Delete Event (NGO)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ngoToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{apiUrl}}/events/1",
              "host": ["{{apiUrl}}"],
              "path": ["events", "1"]
            }
          }
        },
        {
          "name": "Get Events by NGO",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ngoToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{apiUrl}}/events/ngo/5",
              "host": ["{{apiUrl}}"],
              "path": ["events", "ngo", "5"]
            }
          }
        }
      ]
    },
    {
      "name": "Enrollments",
      "item": [
        {
          "name": "Enroll in Event (Volunteer)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{volunteerToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{apiUrl}}/events/1/enroll",
              "host": ["{{apiUrl}}"],
              "path": ["events", "1", "enroll"]
            }
          }
        },
        {
          "name": "Get Event Participants (NGO)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ngoToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{apiUrl}}/events/1/participants",
              "host": ["{{apiUrl}}"],
              "path": ["events", "1", "participants"]
            }
          }
        },
        {
          "name": "Cancel Enrollment (Volunteer)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{volunteerToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{apiUrl}}/events/1/enroll",
              "host": ["{{apiUrl}}"],
              "path": ["events", "1", "enroll"]
            }
          }
        },
        {
          "name": "Get User Enrollments",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{volunteerToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{apiUrl}}/events/users/1/events",
              "host": ["{{apiUrl}}"],
              "path": ["events", "users", "1", "events"]
            }
          }
        },
        {
          "name": "Mark Participation Complete (NGO)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ngoToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 1\n}"
            },
            "url": {
              "raw": "{{apiUrl}}/events/1/complete",
              "host": ["{{apiUrl}}"],
              "path": ["events", "1", "complete"]
            }
          }
        },
        {
          "name": "Get Event Statistics (NGO)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ngoToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{apiUrl}}/events/1/stats",
              "host": ["{{apiUrl}}"],
              "path": ["events", "1", "stats"]
            }
          }
        }
      ]
    },
    {
      "name": "Error Cases",
      "item": [
        {
          "name": "Get Non-existent Event",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiUrl}}/events/999",
              "host": ["{{apiUrl}}"],
              "path": ["events", "999"]
            }
          }
        },
        {
          "name": "Create Event without Auth",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ngo_id\": 5,\n  \"title\": \"Unauthorized Event\",\n  \"description\": \"This should fail\",\n  \"location\": \"Test Location\",\n  \"date_time\": \"2024-03-15T09:00:00.000Z\"\n}"
            },
            "url": {
              "raw": "{{apiUrl}}/events",
              "host": ["{{apiUrl}}"],
              "path": ["events"]
            }
          }
        },
        {
          "name": "Create Event with Invalid Data",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ngoToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ngo_id\": 5,\n  \"title\": \"ab\",\n  \"description\": \"This should fail validation\",\n  \"location\": \"Test Location\",\n  \"date_time\": \"2020-01-01T09:00:00.000Z\"\n}"
            },
            "url": {
              "raw": "{{apiUrl}}/events",
              "host": ["{{apiUrl}}"],
              "path": ["events"]
            }
          }
        },
        {
          "name": "Enroll in Non-existent Event",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{volunteerToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{apiUrl}}/events/999/enroll",
              "host": ["{{apiUrl}}"],
              "path": ["events", "999", "enroll"]
            }
          }
        }
      ]
    }
  ]
}
